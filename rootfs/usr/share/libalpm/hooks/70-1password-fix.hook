[Trigger]
Operation = Install
Operation = Upgrade
Type = Package
Target = 1password

[Action]
Description = Fix 1Password permissions and sandbox bits
When = PostTransaction
Exec = /usr/bin/bash -c 'find /opt/1Password -type d -exec chmod 755 {} + && find /opt/1Password -type f -exec chmod 644 {} + && chmod 755 /opt/1Password/1password /opt/1Password/op-ssh-sign 2>/dev/null || true && chmod 4755 /opt/1Password/chrome-sandbox'