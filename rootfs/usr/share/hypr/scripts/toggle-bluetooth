#!/bin/sh
set -eu

notify() {
    command -v notify-send >/dev/null 2>&1 || return 0
    notify-send "Bluetooth" "$1"
}

powered="$(
    bluetoothctl show 2>/dev/null | sed -n 's/^[[:space:]]*Powered: //p' | head -n 1 || true
)"

case "$powered" in
  yes)
    bluetoothctl power off >/dev/null
    notify "Off"
    ;;
  no)
    bluetoothctl power on >/dev/null
    notify "On"
    ;;
  *)
    notify "No controller available"
    exit 0
    ;;
esac
