#!/usr/bin/env python3
import json
import re
import shutil
import subprocess
import time
from pathlib import Path
from urllib.parse import urlparse

SUPPORTED_CLASSES = {
    "firefox",
    "firefox_firefox",
    "google-chrome",
    "google-chrome-stable",
    "chromium",
    "chromium-browser",
    "brave-browser",
    "microsoft-edge",
    "microsoft-edge-beta",
    "microsoft-edge-dev",
    "vivaldi-stable",
    "vivaldi",
}
URL_RE = re.compile(r"^[a-zA-Z][a-zA-Z0-9+.-]*://")
LOG_PATH = Path.home() / ".cache" / "browser-tab-to-chrome-app.log"


def run_capture(cmd: list[str]) -> str:
    try:
        proc = subprocess.run(cmd, check=False, capture_output=True, text=True)
        return proc.stdout.strip()
    except FileNotFoundError:
        return ""


def run_capture_bytes(cmd: list[str]) -> bytes:
    try:
        proc = subprocess.run(cmd, check=False, capture_output=True)
        return proc.stdout
    except FileNotFoundError:
        return b""


def notify(title: str, body: str) -> None:
    subprocess.run(["notify-send", title, body], check=False)


def log(message: str) -> None:
    LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
    with LOG_PATH.open("a", encoding="utf-8") as handle:
        handle.write(f"{time.strftime('%Y-%m-%d %H:%M:%S')} {message}\n")


def command_exists(name: str) -> bool:
    return shutil.which(name) is not None


def active_window() -> dict:
    out = run_capture(["hyprctl", "-j", "activewindow"])
    if not out:
        return {}
    try:
        data = json.loads(out)
    except json.JSONDecodeError:
        return {}
    return data if isinstance(data, dict) else {}


def clipboard_read() -> bytes:
    return run_capture_bytes(["wl-paste", "--no-newline"])


def clipboard_write(data: bytes) -> None:
    proc = subprocess.Popen(["wl-copy", "--type", "text/plain"], stdin=subprocess.PIPE)
    proc.communicate(data)


def run_wtype(*args: str) -> None:
    subprocess.run(["wtype", *args], check=False)


def focus_address_bar_shortcuts() -> None:
    sequences = [
        ("-M", "ctrl", "-k", "l", "-m", "ctrl"),
        ("-k", "F6"),
        ("-M", "alt", "-k", "d", "-m", "alt"),
    ]
    for sequence in sequences:
        run_wtype(*sequence)
        time.sleep(0.18)


def press_copy_url_sequence() -> None:
    focus_address_bar_shortcuts()
    run_wtype("-M", "ctrl", "-k", "c", "-m", "ctrl")
    time.sleep(0.18)
    run_wtype("-k", "Escape")


def wait_for_url(previous: bytes) -> str:
    for _ in range(40):
        current = clipboard_read()
        if current != previous:
            text = current.decode("utf-8", errors="ignore").strip()
            log(f"clipboard changed to: {text[:200]!r}")
            if is_url(text):
                return text
        time.sleep(0.05)

    text = clipboard_read().decode("utf-8", errors="ignore").strip()
    log(f"clipboard final content: {text[:200]!r}")
    return text if is_url(text) else ""


def is_url(text: str) -> bool:
    if not text:
        return False
    if URL_RE.match(text):
        parsed = urlparse(text)
        return bool(parsed.scheme and parsed.netloc)
    return False


def chrome_binary() -> str | None:
    for candidate in ("google-chrome-stable", "google-chrome", "chromium", "chromium-browser"):
        if command_exists(candidate):
            return candidate
    return None


def launch_app(url: str) -> None:
    browser = chrome_binary()
    if not browser:
        notify("Browser App", "No Chrome or Chromium binary found")
        raise SystemExit(1)

    cmd = ["uwsm", "app", "--", browser, f"--app={url}"]
    subprocess.Popen(
        cmd,
        stdin=subprocess.DEVNULL,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )


def main() -> int:
    if not command_exists("wtype"):
        notify("Browser App", "Install wtype to enable this hotkey")
        return 1

    win = active_window()
    klass = str(win.get("class") or "")
    if klass not in SUPPORTED_CLASSES:
        notify("Browser App", f"Active window is not a supported browser: {klass or 'unknown'}")
        return 1

    previous_clipboard = clipboard_read()
    log(f"active class={klass!r} title={str(win.get('title') or '')!r}")
    press_copy_url_sequence()
    url = wait_for_url(previous_clipboard)
    clipboard_write(previous_clipboard)

    if not is_url(url):
        current = clipboard_read().decode("utf-8", errors="ignore").strip()
        log(f"url detection failed; clipboard now: {current[:200]!r}")
        notify("Browser App", "Could not read URL from the active tab")
        return 1

    launch_app(url)
    notify("Browser App", url)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
