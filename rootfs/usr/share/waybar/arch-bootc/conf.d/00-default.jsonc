{
    "height": 40,
    "spacing": 5,
    "modules-left": ["hyprland/workspaces","hyprland/window"],
    "modules-center": [],
    "modules-right": ["custom/codex-usage", "custom/claude-usage", "custom/colorscheme", "backlight", "pulseaudio#out", "pulseaudio#in", "network", "bluetooth", "memory", "temperature", "battery", "tray", "clock#date", "clock#time", "custom/notification"],
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{name}"
    },
    "custom/colorscheme": {
        "interval": 1,
        "return-type": "json",
        "format": "{icon}",
        "format-icons": {
            "prefer-dark": "\uF186",
            "prefer-light": "\uF185пёЏ"
        },
        "on-click": "if [ \"$(gsettings get org.gnome.desktop.interface color-scheme)\" = \"'prefer-dark'\" ]; then gsettings set org.gnome.desktop.interface color-scheme 'prefer-light' && gsettings set org.gnome.desktop.interface gtk-theme Adwaita; else gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark' && gsettings set org.gnome.desktop.interface gtk-theme Adwaita-dark; fi",
        "exec": "gsettings get org.gnome.desktop.interface color-scheme | tr -d \"'\" | jq -R '{\"text\": .,\"alt\": .,\"tooltip\": .,\"class\": ., \"percentage\": null}'  --unbuffered --compact-output",
        "exec-on-event": true
    },
    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": [
            "у°ѓћ",
            "у°ѓџ",
            "у°ѓќ",
            "у°ѓ "
        ]
    },
    "pulseaudio#out": {
        "format": "{volume}% {icon} ",
        "format-bluetooth": "{volume}% {icon} пЉ”",
        "format-bluetooth-muted": "пљ© {icon} пЉ”",
        "format-muted": "пљ©",
        "format-icons": {
            "headphone": "пЂҐ",
            "hands-free": "п–ђ",
            "headset": "п–ђ",
            "phone": "п‚•",
            "portable": "п‚•",
            "car": "п†№",
            "default": ["пЂ¦", "пЂ§", "пЂЁ"]
        },
        "on-click": "pavucontrol -t 3"
    },
    "pulseaudio#in": {
        "format": "{format_source}",
        "format-source": "п„°",
        "format-source-muted": "п„± ",
        "on-click": "pavucontrol -t 4"
    },
    "network": {
        "interface": "wlp3s0",
        "family": "ipv4",
        "format-wifi": "{essid} ({signalStrength}%) п‡« ",
        "format-ethernet": "{ipaddr}/{cidr} пћ– ",
        "tooltip-format": "{ifname} via {gwaddr} пћ–",
        "format-linked": "{ifname} (No IP) пћ– ",
        "format-disconnected": "Disconnected вљ ",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "tooltip": false
    },
    "bluetooth": {
        "format-connected": "у°‚± {device_battery_percentage}%",
        "format-on": "пЉ”",
        "format-off": "у°‚І",
        "format-disabled": "у°‚І",
        "format-no-controller": "у°‚І",
        "on-click": "blueman-manager"
    },
    "tray": {
        "spacing": 10
    },
    "clock#date": {
        "timezone": "Europe/London",
        "format": "{:%A %d %B %Y}",
        "tooltip": false
    },
    "clock#time": {
        "timezone": "Europe/London",
        "format": "{:%I:%M %p}",
        "tooltip": false
    },
    "memory": {
        "format": "{}% пѓ‰"
    },
    "temperature": {
        "critical-threshold": 80,
        "format": "{temperatureC}В°C {icon}",
        "format-icons": ["пќ«", "п‹‰", "пќ©"]
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% п—§",
        "format-plugged": "{capacity}% п‡¦",
        "format-alt": "{time} {icon}",
        "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"]
    },
    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "п‚ў<span foreground='red'><sup>п‘„</sup></span>",
            "none": "п‚ў",
            "dnd-notification": "п‡·<span foreground='red'><sup>п‘„</sup></span>",
            "dnd-none": "п‡·",
            "inhibited-notification": "п‚ў<span foreground='red'><sup>п‘„</sup></span>",
            "inhibited-none": "п‚ў",
            "dnd-inhibited-notification": "п‡·<span foreground='red'><sup>п‘„</sup></span>",
            "dnd-inhibited-none": "п‡·"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    }
}
